# ==============================================================
# SiloGenius — Environment Configuration
# ==============================================================
# Copy this file to .env and fill in your values
# cp env.example .env
# ==============================================================

# --------------------------------------------------------------
# OpenRouter (Required for Silo Generator and Article Writer)
# Get your key at: https://openrouter.io/keys
# --------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --------------------------------------------------------------
# Google AI Studio (Required for Image Generation)
# Get your key at: https://aistudio.google.com/apikey
# Free tier: 1,500 images/day, 2 images/minute
# --------------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# --------------------------------------------------------------
# Anthropic (Optional - for Claude models via Settings)
# Get your key at: https://console.anthropic.com/
# --------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --------------------------------------------------------------
# OpenAI (Optional - for GPT models via Settings)
# Get your key at: https://platform.openai.com/api-keys
# --------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# --------------------------------------------------------------
# WordPress Connection
# Create an Application Password in WordPress:
# Users -> Profile -> Application Passwords
# --------------------------------------------------------------
WP_URL=http://yoursite.com/wordpress
WP_USERNAME=your_wordpress_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --------------------------------------------------------------
# Model Configuration
# These are set automatically via the Settings page
# Default values shown below
# --------------------------------------------------------------
SILO_MODEL=arcee-ai/trinity-large-preview:free
ARTICLE_MODEL=arcee-ai/trinity-large-preview:free
IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
GOOGLE_IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
